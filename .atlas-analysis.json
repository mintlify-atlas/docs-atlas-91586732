  "keyFeatures": [
    "Multi-site management from a single Rails installation",
    "Custom content types and custom fields without coding",
    "Plugin system with hooks for extending functionality",
    "Theme system with layout and template support",
    "Advanced user roles and permissions (CanCanCan-based)",
    "File uploads with local and Amazon S3 support",
    "Multi-language / i18n support for frontend and admin",
    "Built-in SEO, sitemap, and RSS generation",
    "Shortcodes and widgets",
    "Easy migration from WordPress"
  ],
  "publicApiSurface": [
    "rails generate camaleon_cms:install",
    "rails generate camaleon_cms:gem_plugin",
    "rails generate camaleon_cms:theme",
    "rake camaleon_cms:generate_migrations",
